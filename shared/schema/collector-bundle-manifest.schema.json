{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/incident-response-kit/schema/collector-bundle-manifest.schema.json",
  "title": "Collector Bundle Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "batch_id",
    "case_id",
    "collected_at",
    "collector",
    "operator",
    "target_host",
    "profile",
    "artifacts",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "bundle_id": { "type": "string" },
    "batch_id": { "type": "string" },
    "case_id": { "type": "string" },
    "collected_at": { "type": "string", "format": "date-time" },
    "collector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "mode"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "mode": { "type": "string", "enum": ["no-admin-baseline", "elevated", "debug"] },
        "usb_serial": { "type": ["string", "null"] }
      }
    },
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operator_id"],
      "properties": {
        "operator_id": { "type": "string" },
        "notes": { "type": ["string", "null"] }
      }
    },
    "target_host": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hostname", "username", "os_family"],
      "properties": {
        "hostname": { "type": "string" },
        "username": { "type": "string" },
        "domain": { "type": ["string", "null"] },
        "os_family": { "type": "string", "enum": ["windows", "macos", "linux"] },
        "os_version": { "type": ["string", "null"] },
        "architecture": { "type": ["string", "null"] },
        "timezone": { "type": ["string", "null"] },
        "boot_time": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "artifact_policy_version": { "type": ["string", "null"] }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "./artifact-record.schema.json"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_count", "errors", "warnings"],
      "properties": {
        "artifact_count": { "type": "integer", "minimum": 0 },
        "errors": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "status": { "type": "string", "enum": ["ok", "partial", "failed"] }
      }
    }
  }
}
